package com.flm.Repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import com.flm.model.Student;

@Repository
public interface StudentRepository extends JpaRepository<Student, Integer>{
	

	@Query("SELECT s from Student s where s.studentId =:id ")
	public Student getStudentById(@Param("id") int id);
	
	@Query("SELECT s from Student s where s.marks=?1")
	public List<Student> getStudentsBasedOnMarks(int marks);
	
}
